# L.I.R.A. Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=LIRA
APP_VERSION=0.1.0
APP_ENV=development

# API Keys (choose one or more)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk-...

# LLM Configuration
LLM_PROVIDER=local # ollama | groq | local
LLM_MODEL=gemma4:e4b # model name (e.g. gemma4:e4b for ollama, llama3-8b-8192 for groq)

# For finetuned local model (LLM_PROVIDER=local)
LOCAL_MODEL_PATH=/home/davide/Documents/Dev/LIRA/finetune/output/lira-agent

# For local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_KEEP_ALIVE=30m

# Database
DATABASE_URL=sqlite:///./data/lira.db
DATABASE_ECHO=false

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8000

# API Server
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/lira.log

# CLI
CLI_THEME=dark
CLI_COLOR=true

# Feature Flags
ENABLE_AUTO_CATEGORIZATION=true
ENABLE_REAL_TIME_QUOTES=false
ENABLE_NOTIFICATIONS=false

# Security
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001

# External APIs
YAHOO_FINANCE_API_ENABLED=true
EXCHANGE_RATE_API_KEY=
